#!/bin/sh
set -e

VERSION="0.2.2"
CASTFILE="./Castfile"
DRY_RUN=0
VERBOSE=0
HOST_OVERRIDE=""
TARGET_HOST=""
PARALLEL=0

# Literal newline for POSIX compliant string building
NL='
'

usage() {
    cat <<USG
cast $VERSION - minimal SSH deploy tool

Usage: cast [options] <task>

Options:
  -f <file>    Castfile path (default: ./Castfile)
  -h <host>    Override host (user@host)
  -t <name>    Target specific host by name (from Castfile)
  -p           Run on all hosts in parallel
  -n           Dry run (print commands only)
  -v           Verbose output
  --help       Show this help

Examples:
  cast deploy
  cast -p deploy
  cast -t prod deploy
USG
    exit 0
}

log() {
    [ "$VERBOSE" = "1" ] && echo "[cast] $*" >&2
}

err() {
    echo "[cast] error: $*" >&2
    exit 1
}

run_ssh() {
    host="$1"
    cmd="$2"
    prefix="$3"
    if [ "$DRY_RUN" = "1" ]; then
        echo "${prefix}[dry-run] ssh $host '$cmd'"
    else
        log "${prefix}ssh $host '$cmd'"
        if [ -n "$prefix" ]; then
            ssh $SSH_OPTS "$host" "$cmd" 2>&1 | sed "s/^/$prefix/"
        else
            ssh $SSH_OPTS "$host" "$cmd"
        fi
    fi
}

copy_file() {
    host="$1"
    src="$2"
    dst="$3"
    prefix="$4"
    if [ "$DRY_RUN" = "1" ]; then
        echo "${prefix}[dry-run] scp $src $host:$dst"
    else
        log "${prefix}scp $src -> $host:$dst"
        if [ -n "$prefix" ]; then
            scp $SSH_OPTS "$src" "$host:$dst" 2>&1 | sed "s/^/$prefix/"
        else
            scp $SSH_OPTS "$src" "$host:$dst"
        fi
    fi
}

template_str() {
    _str="$1"
    for _k in $VARS; do
        eval "_v=\${VAR_$_k}"
        # Escape sed special chars in the replacement value
        _v_esc=$(printf '%s\n' "$_v" | sed 's/[%&\]/\\&/g')
        _str=$(printf '%s\n' "$_str" | sed 's%\$'"$_k"'%'"$_v_esc"'%g; s%\${'"$_k"'}%'"$_v_esc"'%g')
    done
    printf "%s\n" "$_str"
}

parse_castfile() {
    [ -f "$CASTFILE" ] || err "Castfile not found: $CASTFILE"

    in_task=0
    current_task=""

    while IFS= read -r line || [ -n "$line" ]; do
        # Drop full-line comments and trim whitespace safely
        line=$(printf '%s\n' "$line" | sed 's/^[[:space:]]*#.*$//' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
        [ -z "$line" ] && continue

        case "$line" in
            var\ *)
                key=$(echo "$line" | awk '{print $2}')
                val=$(echo "$line" | cut -d' ' -f3-)
                # Escape single quotes for safe eval
                safe_val=$(printf '%s\n' "$val" | sed "s/'/'\\\\''/g")
                eval "VAR_$key='${safe_val}'"
                VARS="$VARS $key"
                ;;
            host\ *)
                name=$(echo "$line" | awk '{print $2}')
                addr=$(echo "$line" | awk '{print $3}')
                eval "HOST_$name='${addr}'"
                HOSTS="$HOSTS $name"
                ;;
            ssh_opts\ *)
                SSH_OPTS=$(echo "$line" | cut -d' ' -f2-)
                ;;
            task\ *)
                current_task=$(echo "$line" | awk '{print $2}')
                eval "TASK_$current_task=1"
                ;;
            run\ *)
                if [ -n "$current_task" ]; then
                    cmd=$(echo "$line" | cut -d' ' -f2-)
                    safe_cmd=$(printf '%s\n' "$cmd" | sed "s/'/'\\\\''/g")
                    eval "TASK_${current_task}_CMDS=\${TASK_${current_task}_CMDS}'run|${safe_cmd}'\"\${NL}\""
                fi
                ;;
            copy\ *)
                if [ -n "$current_task" ]; then
                    src=$(echo "$line" | awk '{print $2}')
                    dst=$(echo "$line" | awk '{print $3}')
                    safe_cmd=$(printf '%s\n' "$src|$dst" | sed "s/'/'\\\\''/g")
                    eval "TASK_${current_task}_CMDS=\${TASK_${current_task}_CMDS}'copy|${safe_cmd}'\"\${NL}\""
                fi
                ;;
        esac
    done < "$CASTFILE"
}

execute_host() {
    host_name="$1"
    host_addr="$2"
    cmds="$3"
    
    prefix=""
    [ "$PARALLEL" = "1" ] && prefix="[$host_name] "

    echo "${prefix}==> $host_name ($host_addr)"

    printf "%s\n" "$cmds" | while IFS= read -r cmd_line; do
        [ -z "$cmd_line" ] && continue
        cmd_line=$(template_str "$cmd_line")
        type=$(echo "$cmd_line" | cut -d'|' -f1)

        case "$type" in
            run)
                cmd=$(echo "$cmd_line" | cut -d'|' -f2-)
                echo "${prefix}  + $cmd"
                run_ssh "$host_addr" "$cmd" "$prefix"
                ;;
            copy)
                src=$(echo "$cmd_line" | cut -d'|' -f2)
                dst=$(echo "$cmd_line" | cut -d'|' -f3)
                echo "${prefix}  + copy $src -> $dst"
                copy_file "$host_addr" "$src" "$dst" "$prefix"
                ;;
        esac
    done
}

execute_task() {
    task="$1"
    eval "task_exists=\${TASK_$task}"
    [ -n "$task_exists" ] || err "unknown task: $task"

    eval "cmds=\"\${TASK_${task}_CMDS}\""

    if [ -n "$TARGET_HOST" ]; then
        eval "host_addr=\${HOST_$TARGET_HOST}"
        [ -z "$host_addr" ] && err "unknown host: $TARGET_HOST"
        HOST_LIST="$TARGET_HOST"
    else
        HOST_LIST="$HOSTS"
    fi

    for host_name in $HOST_LIST; do
        eval "host_addr=\${HOST_$host_name}"
        [ -n "$HOST_OVERRIDE" ] && host_addr="$HOST_OVERRIDE"

        if [ "$PARALLEL" = "1" ]; then
            execute_host "$host_name" "$host_addr" "$cmds" &
        else
            execute_host "$host_name" "$host_addr" "$cmds"
        fi
    done

    if [ "$PARALLEL" = "1" ]; then
        wait
        echo "==> parallel execution complete"
    fi
}

while [ $# -gt 0 ]; do
    case "$1" in
        -f) CASTFILE="$2"; shift 2 ;;
        -h) HOST_OVERRIDE="$2"; shift 2 ;;
        -t) TARGET_HOST="$2"; shift 2 ;;
        -n) DRY_RUN=1; shift ;;
        -p) PARALLEL=1; shift ;;
        -v) VERBOSE=1; shift ;;
        --help) usage ;;
        -*) err "unknown option: $1" ;;
        *) TASK="$1"; shift ;;
    esac
done

[ -n "$TASK" ] || usage

parse_castfile
execute_task "$TASK"
